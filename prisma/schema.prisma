generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  SELLER
  ADMIN
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DisputeStatus {
  OPEN
  RESOLVED_REFUNDED
  RESOLVED_REJECTED
  CLOSED
}

enum DisputeResolution {
  REFUND_BUYER
  REJECT_DISPUTE
  PARTIAL_REFUND
}

enum ReportType {
  PRODUCT
  USER
  REVIEW
  OTHER
}

enum ReportReason {
  SPAM
  INAPPROPRIATE_CONTENT
  FRAUD
  COPYRIGHT
  HARASSMENT
  MISLEADING
  OTHER
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  REJECTED
  CLOSED
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String
  password            String
  role                UserRole  @default(BUYER)
  avatar              String?
  verified            Boolean   @default(false)
  balance             Int       @default(0)
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String?
  twoFactorBackupCodes String[]  @default([])
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  products      Product[]
  purchases     Purchase[]
  payouts       Payout[]
  reviews       Review[]
  disputes      Dispute[]
  disputeMessages DisputeMessage[]
  reports       Report[]

  @@index([email])
  @@index([role])
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  icon        String
  description String?
  parentId    String?
  createdAt   DateTime  @default(now())

  parent      Category?  @relation("CategoryToSubcategory", fields: [parentId], references: [id], onDelete: Cascade)
  subcategories Category[] @relation("CategoryToSubcategory")
  products    Product[]

  @@index([slug])
  @@index([parentId])
}

model Product {
  id            String        @id @default(cuid())
  title         String
  description   String
  price         Int
  coverImage    String?
  fileUrl       String
  fileName      String
  fileSize      Int
  status        ProductStatus @default(DRAFT)
  downloadCount Int           @default(0)
  hasLicenseKeys Boolean      @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sellerId      String
  seller        User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  categoryId    String
  category      Category      @relation(fields: [categoryId], references: [id])

  purchases     Purchase[]
  reviews       Review[]
  licenseKeys   LicenseKey[]
  images        ProductImage[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([status])
  @@index([price])
}

model Purchase {
  id                String         @id @default(cuid())
  amount            Int
  commission        Int
  sellerEarnings    Int
  yookassaPaymentId String?
  status            PurchaseStatus @default(PENDING)
  downloadToken     String?        @unique
  downloadCount     Int            @default(0)
  downloadExpiresAt DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  buyerId           String
  buyer             User           @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  productId         String
  product           Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  licenseKeyId      String?        @unique
  licenseKey        LicenseKey?    @relation(fields: [licenseKeyId], references: [id])

  downloadLogs      DownloadLog[]
  dispute           Dispute?

  @@index([buyerId])
  @@index([productId])
  @@index([status])
  @@index([downloadToken])
}

model Payout {
  id             String       @id @default(cuid())
  amount         Int
  status         PayoutStatus @default(PENDING)
  method         String?
  accountDetails String?
  requestedAt    DateTime     @default(now())
  processedAt    DateTime?

  sellerId       String
  seller         User         @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([status])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  buyerId   String
  buyer     User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([buyerId, productId])
  @@index([productId])
}

model DownloadLog {
  id           String   @id @default(cuid())
  ipAddress    String?
  userAgent    String?
  downloadedAt DateTime @default(now())

  purchaseId   String
  purchase     Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
}

model LicenseKey {
  id          String    @id @default(cuid())
  key         String
  isSold      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  soldAt      DateTime?

  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  purchase    Purchase?

  @@index([productId])
  @@index([isSold])
}

model ProductImage {
  id        String   @id @default(cuid())
  imageUrl  String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([order])
}

model PlatformSettings {
  id                      String   @id @default(cuid())
  commissionRate          Int      @default(10)
  minPayoutAmount         Int      @default(100000)
  maxFileSize             Int      @default(500)
  notifyNewUser           Boolean  @default(true)
  notifyNewProduct        Boolean  @default(true)
  notifyNewPurchase       Boolean  @default(true)
  notifyPayoutRequest     Boolean  @default(true)
  notifyReportSubmission  Boolean  @default(false)
  requireEmailVerification Boolean @default(false)
  enableTwoFactor         Boolean  @default(false)
  sessionTimeout          Int      @default(24)
  maxLoginAttempts        Int      @default(5)
  updatedAt               DateTime @updatedAt
}

model Dispute {
  id              String          @id @default(cuid())
  reason          String
  status          DisputeStatus   @default(OPEN)
  resolution      DisputeResolution?
  resolutionNote  String?
  refundAmount    Int?
  createdAt       DateTime        @default(now())
  resolvedAt      DateTime?
  updatedAt       DateTime        @updatedAt

  purchaseId      String          @unique
  purchase        Purchase        @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  buyerId         String
  buyer           User            @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  messages        DisputeMessage[]

  @@index([buyerId])
  @@index([status])
  @@index([createdAt])
}

model DisputeMessage {
  id          String   @id @default(cuid())
  message     String
  isFromBuyer Boolean
  createdAt   DateTime @default(now())

  disputeId   String
  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  senderId    String
  sender      User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@index([createdAt])
}

model Report {
  id              String        @id @default(cuid())
  type            ReportType
  reason          ReportReason
  description     String
  status          ReportStatus  @default(PENDING)
  adminNote       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  resolvedAt      DateTime?

  reporterId      String
  reporter        User          @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  // Nullable references to what's being reported
  reportedUserId  String?
  reportedProductId String?
  reportedReviewId String?

  @@index([reporterId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}
